{
  "name": "@matyah00/openpi",
  "version": "0.2.1",
  "type": "module",
  "description": "Comprehensive, high-performance, and safety-hardened Pi-native multi-agent orchestration package, featuring advanced workflows, damage-control rules, and developer tooling.",
  "keywords": [
    "pi-package",
    "pi-coding-agent",
    "commands",
    "skills",
    "agents",
    "workflows",
    "orchestration",
    "safety",
    "multi-agent",
    "damage-control"
  ],
  "homepage": "https://github.com/haytamAroui/OpenPi#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haytamAroui/OpenPi.git"
  },
  "bugs": {
    "url": "https://github.com/haytamAroui/OpenPi/issues"
  },
  "license": "MIT",
  "files": [
    "agents",
    "extensions",
    "prompts",
    "scripts",
    "skills",
    "themes",
    "types",
    "damage-control-rules.yaml",
    "LICENSE",
    "README.md",
    "tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "npm run validate && npm run typecheck && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate-package.mjs"
  },
  "dependencies": {
    "yaml": "^2.8.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/openpi.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ],
    "themes": [
      "./themes"
    ]
  }
}
